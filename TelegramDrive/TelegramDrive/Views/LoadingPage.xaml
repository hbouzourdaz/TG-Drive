<Page
    x:Class="TelegramDrive.Views.LoadingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Spacing="16" HorizontalAlignment="Center">
            <!-- Brand Title -->
            <TextBlock
                Text="Saved Messages Drive"
                Foreground="{StaticResource TgPrimaryBrush}"
                FontSize="26" FontWeight="Bold"
                FontFamily="{StaticResource TgFontFamily}"
                HorizontalAlignment="Center" />

            <!-- Status Message -->
            <TextBlock
                x:Name="StatusText"
                Text="Loading..."
                Foreground="{StaticResource TgTextSecondaryBrush}"
                FontSize="13"
                FontFamily="{StaticResource TgFontFamily}"
                HorizontalAlignment="Center" />

            <!-- Progress Ring -->
            <ProgressRing
                IsActive="True"
                Width="40" Height="40"
                Foreground="{StaticResource TgPrimaryBrush}" />
        </StackPanel>
    </Grid>
</Page>
