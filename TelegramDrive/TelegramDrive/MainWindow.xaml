<Window
    x:Class="TelegramDrive.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Telegram Unlimited Cloud Storage">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom drag-region title bar -->
        <Grid Grid.Row="0" x:Name="AppTitleBar" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0" Spacing="10">
                <TextBlock Text="Telegram Unlimited Cloud Storage" 
                           Foreground="#FF7F91A4" 
                           FontSize="12" 
                           FontWeight="Medium"
                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif" 
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Frame Grid.Row="1" x:Name="ContentFrame">
            <Frame.ContentTransitions>
                <TransitionCollection />
            </Frame.ContentTransitions>
        </Frame>
    </Grid>
</Window>
