<Page
    x:Class="TelegramDrive.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Accounts Selection Card -->
        <Border x:Name="AccountsSection" Grid.Row="0" Style="{StaticResource TgCardStyle}" Width="420" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
            <StackPanel Spacing="15">
                <!-- Title -->
                <TextBlock
                    x:Name="WelcomeBackTitle"
                    Text="Welcome Back"
                    Foreground="{StaticResource TgPrimaryBrush}"
                    FontSize="22" FontWeight="Bold"
                    FontFamily="{StaticResource TgFontFamily}"
                    HorizontalAlignment="Center" />

                <TextBlock
                    x:Name="WelcomeBackSubtitle"
                    Text="Select an account to login instantly."
                    Foreground="{StaticResource TgTextSecondaryBrush}"
                    FontSize="11"
                    FontFamily="{StaticResource TgFontFamily}"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,10" />

                <!-- Accounts List -->
                <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="AccountsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource TgBgInputBrush}" 
                                        BorderBrush="{StaticResource TgBgDividerBrush}" 
                                        BorderThickness="1" 
                                        CornerRadius="10" 
                                        Margin="0,0,0,8" 
                                        Padding="12,8"
                                        HorizontalAlignment="Stretch">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Avatar character or circle -->
                                        <Border Grid.Column="0" Width="30" Height="30" CornerRadius="15" Background="{StaticResource TgPrimaryLightBrush}" VerticalAlignment="Center">
                                            <TextBlock Text="👤" Foreground="{StaticResource TgPrimaryBrush}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        
                                        <!-- Info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,10,0">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TgTextPrimaryBrush}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Phone}" Foreground="{StaticResource TgTextSecondaryBrush}" FontSize="10" />
                                        </StackPanel>
                                        
                                        <!-- Actions -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <!-- Login Button -->
                                            <Button Content="Login" Tag="{Binding Phone}" Click="OnInstantLoginClick"
                                                    Background="{StaticResource TgPrimaryBrush}" Foreground="White" 
                                                    BorderThickness="0" CornerRadius="5" FontSize="11" FontWeight="SemiBold" Height="28" Padding="10,0" />
                                            <!-- Delete Button -->
                                            <Button Content="🗑️" Tag="{Binding Phone}" Click="OnDeleteAccountClick"
                                                    Background="Transparent" BorderThickness="0" CornerRadius="5" FontSize="12" Height="28" Width="28" Padding="0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Switch to another account -->
                <Button x:Name="UseAnotherBtn" Content="Login with another account"
                    Style="{StaticResource TgGhostButtonStyle}"
                    Foreground="{StaticResource TgPrimaryBrush}"
                    Click="OnUseAnotherClick" HorizontalAlignment="Stretch" Margin="0,5,0,0" />
            </StackPanel>
        </Border>

        <!-- Login Card -->
        <Border x:Name="LoginFormSection" Grid.Row="0" Style="{StaticResource TgCardStyle}" Width="420" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Spacing="10">
                <!-- Title -->
                <TextBlock
                    x:Name="TitleText"
                    Text="Telegram Cloud Storage"
                    Foreground="{StaticResource TgPrimaryBrush}"
                    FontSize="22" FontWeight="Bold"
                    FontFamily="{StaticResource TgFontFamily}"
                    HorizontalAlignment="Center" />

                <TextBlock
                    x:Name="SubtitleText"
                    Text="Enter API ID &amp; API Hash to link secure storage."
                    Foreground="{StaticResource TgTextSecondaryBrush}"
                    FontSize="11"
                    FontFamily="{StaticResource TgFontFamily}"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,10" />

                <!-- API ID -->
                <TextBlock x:Name="ApiIdLabel" Text="Telegram API ID" Foreground="{StaticResource TgTextSecondaryBrush}"
                    FontSize="12" FontFamily="{StaticResource TgFontFamily}" />
                <TextBox x:Name="ApiIdBox" PlaceholderText="e.g. 123456"
                    Style="{StaticResource TgTextBoxStyle}" />

                <!-- API Hash -->
                <TextBlock x:Name="ApiHashLabel" Text="Telegram API HASH" Foreground="{StaticResource TgTextSecondaryBrush}"
                    FontSize="12" FontFamily="{StaticResource TgFontFamily}" />
                <TextBox x:Name="ApiHashBox" PlaceholderText="e.g. 7ba45fa8f090..."
                    Style="{StaticResource TgTextBoxStyle}" />

                <!-- Phone Number -->
                <TextBlock x:Name="PhoneLabel" Text="Phone Number (International)" Foreground="{StaticResource TgTextSecondaryBrush}"
                    FontSize="12" FontFamily="{StaticResource TgFontFamily}" />
                <TextBox x:Name="PhoneBox" PlaceholderText="e.g. +1234567890"
                    Style="{StaticResource TgTextBoxStyle}" />

                <!-- Status Label -->
                <TextBlock x:Name="StatusLabel" Text="" FontSize="11"
                    FontFamily="{StaticResource TgFontFamily}"
                    Foreground="{StaticResource TgPrimaryBrush}"
                    TextWrapping="Wrap" HorizontalAlignment="Center"
                    Margin="0,5,0,0" />

                <!-- Send Code Button -->
                <Button x:Name="SendCodeBtn" Content="Send Verification Code"
                    Style="{StaticResource TgPrimaryButtonStyle}"
                    Click="OnSendCodeClick" Margin="0,10,0,0" />

                <!-- Help Link -->
                <Button x:Name="HelpBtn" Content="ℹ️ How to get API ID / API Hash?"
                    Style="{StaticResource TgGhostButtonStyle}"
                    Foreground="{StaticResource TgWarningBrush}"
                    Click="OnHelpClick" HorizontalAlignment="Stretch" />

                <!-- QR Login Link (currently informational) -->
                <Button x:Name="QrBtn" Content="Scan QR Code to Login Direct"
                    Style="{StaticResource TgGhostButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Click="OnQrClick" />

                <!-- Back to saved accounts button inside LoginFormSection -->
                <Button x:Name="BackToAccountsBtn" Content="⬅️ Back to saved accounts"
                    Style="{StaticResource TgGhostButtonStyle}"
                    Foreground="{StaticResource TgTextSecondaryBrush}"
                    Click="OnBackToAccountsClick" HorizontalAlignment="Stretch" Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <!-- Copyright & Language Footer Grid -->
        <Grid Grid.Row="1" Margin="20,0,20,20" HorizontalAlignment="Stretch" VerticalAlignment="Center">
            <!-- Centered Copyright Capsule -->
            <Border Background="{StaticResource TgBgInputBrush}" 
                    BorderBrush="{StaticResource TgBgDividerBrush}" 
                    BorderThickness="1" 
                    CornerRadius="16" 
                    Padding="16,6"
                    HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="✨" FontSize="11" VerticalAlignment="Center" />
                    <TextBlock x:Name="CopyrightLabel" Text="Designed &amp; Developed by" 
                               Foreground="{StaticResource TgTextSecondaryBrush}" 
                               FontSize="11" 
                               FontFamily="{StaticResource TgFontFamily}" 
                               VerticalAlignment="Center" />
                    <TextBlock Text="Hakim Bouzourdaz" 
                               Foreground="{StaticResource TgPrimaryBrush}" 
                               FontSize="11" 
                               FontWeight="SemiBold"
                               FontFamily="{StaticResource TgFontFamily}" 
                               VerticalAlignment="Center" />
                    <TextBlock Text="• © 2026" 
                               Foreground="{StaticResource TgTextMutedBrush}" 
                               FontSize="10" 
                               FontFamily="{StaticResource TgFontFamily}" 
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Language Switcher in bottom right -->
            <Button x:Name="LangBtn" Content="🌐 English" 
                    Click="OnLangClick"
                    Style="{StaticResource TgGhostButtonStyle}" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Center" 
                    Height="32" Padding="12,0" />
        </Grid>
    </Grid>
</Page>
